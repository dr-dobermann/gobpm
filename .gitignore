# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
*.log

# Test binary, built with `go test -c`
*.test
coverage.*

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/
bin/
generated/*

# Editor / app artifacts
**/.obsidian/

# Stale config backups
*.bck.yml
*.bkp

# Go workspace mode — developer-machine state for cross-module dev (ADR-003 §8.4)
go.work
go.work.sum

# Built example binaries (created by `go build` / `make build-all` inside each
# example module). Examples are source-only; binaries do not belong in git.
